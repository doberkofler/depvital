{
	"name": "depvital",
	"version": "0.5.0",
	"description": "A production-ready CLI tool for analyzing project dependencies' health, security, and maintenance.",
	"keywords": [
		"audit",
		"cli",
		"dependencies",
		"health",
		"maintenance",
		"npm",
		"security",
		"vulnerability"
	],
	"homepage": "https://github.com/doberkofler/depvital#readme",
	"bugs": {
		"url": "https://github.com/doberkofler/depvital/issues"
	},
	"license": "MIT",
	"author": "Dieter Oberkofler <1009585+doberkofler@users.noreply.github.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/doberkofler/depvital.git"
	},
	"bin": "./dist/index.js",
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CONTRIBUTING.md",
		"CHANGELOG.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"scripts": {
		"lint": "tsc && oxlint --disable-nested-config src client server tests *.config.ts && pnpm run format:check",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"test": "vitest run --coverage",
		"ci": "pnpm run lint && pnpm run build && pnpm run test",
		"create-changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
		"prepare": "husky",
		"dev": "vite build --watch",
		"build": "vite build",
		"integration-test": "node -e \"\""
	},
	"dependencies": {
		"@inquirer/prompts": "8.3.2",
		"cli-progress": "3.12.0",
		"commander": "14.0.3",
		"debug": "4.4.3",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@types/cli-progress": "3.11.6",
		"@types/debug": "4.1.13",
		"@types/node": "25.5.2",
		"@vitest/coverage-v8": "4.1.2",
		"conventional-changelog": "7.2.0",
		"eslint-plugin-regexp": "3.1.0",
		"husky": "9.1.7",
		"oxfmt": "0.43.0",
		"oxlint": "1.58.0",
		"oxlint-tsgolint": "0.19.0",
		"typescript": "6.0.2",
		"vite": "8.0.3",
		"vitest": "4.1.2"
	},
	"engines": {
		"node": ">=22"
	},
	"create-template-project": {
		"template": "cli"
	}
}
